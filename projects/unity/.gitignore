# Unity project ignores (applied from monorepo root)
# Patterns use ** to match inside any Unity project under this directory

# IDE / editor caches
**/.vs/
**/.gradle/
**/.consulo/
**/ExportedObj/

# Unity generated directories
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/
**/.utmp/

# Autogenerated solution/project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.vsconfig

# Unity meta files for debug symbols
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Logs and crash reports
*.log
sysinfo.txt
mono_crash.*

# Build outputs
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Blender temp files
*.blend1
*.blend1.meta

# Jetbrains Rider
**/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Crashlytics
crashlytics-build.properties

# TestRunner / Addressables / Visual Scripting generated
**/InitTestScene*.unity*
**/ServerData
**/[Aa]ssets/StreamingAssets/aa*
**/[Aa]ssets/AddressableAssetsData/link.xml*
**/[Aa]ssets/Addressables_Temp*
**/[Aa]ssets/AddressableAssetsData/*/*.bin*
**/[Aa]ssets/Unity.VisualScripting.Generated/
**/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
