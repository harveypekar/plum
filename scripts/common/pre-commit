#!/bin/bash
# Master pre-commit hook — runs all checks, reports all failures.
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only)
FAILED=0

header() { echo ""; echo "── $1 ──"; }
fail()   { FAILED=1; }

# ── Check: required tools ───────────────────────────────────────────

check_tools() {
    local missing=0
    if ! command -v shellcheck &>/dev/null; then
        echo "  ERROR: shellcheck not installed (apt install shellcheck / brew install shellcheck)"
        missing=1
    fi
    if ! command -v ruff &>/dev/null && ! command -v flake8 &>/dev/null; then
        echo "  ERROR: ruff not installed (pipx install ruff)"
        missing=1
    fi
    return $missing
}

header "tool check"
if ! check_tools; then
    echo "  Install missing tools and retry."
    exit 1
fi

# ── Check 1: secrets ────────────────────────────────────────────────

header "secrets"
if ! python3 "$REPO_ROOT/scripts/common/validate-secrets.py"; then
    fail
fi

# ── Check 2: CRLF line endings ─────────────────────────────────────

header "crlf"
crlf_found=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ -f "$f" ] || continue
    if git diff --cached -- "$f" | grep -qP '\r$'; then
        echo "  CRLF detected: $f"
        crlf_found=1
    fi
done <<< "$STAGED_FILES"
if [ "$crlf_found" -eq 1 ]; then
    echo "  Fix: dos2unix <file> or configure git (core.autocrlf=input)"
    fail
fi

# ── Check 3: shellcheck ────────────────────────────────────────────

header "shellcheck"
sh_files=$(echo "$STAGED_FILES" | grep '\.sh$' || true)
if [ -n "$sh_files" ]; then
    sc_failed=0
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$f" ] || continue
        if ! shellcheck "$f" 2>&1; then
            sc_failed=1
        fi
    done <<< "$sh_files"
    if [ "$sc_failed" -eq 1 ]; then
        fail
    fi
else
    echo "  (no .sh files staged)"
fi

# ── Check 4: Python lint ───────────────────────────────────────────

header "ruff"
py_files=$(echo "$STAGED_FILES" | grep '\.py$' || true)
if [ -n "$py_files" ]; then
    lint_failed=0
    if command -v ruff &>/dev/null; then
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            [ -f "$f" ] || continue
            if ! ruff check "$f" 2>&1; then
                lint_failed=1
            fi
        done <<< "$py_files"
    else
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            [ -f "$f" ] || continue
            if ! flake8 "$f" 2>&1; then
                lint_failed=1
            fi
        done <<< "$py_files"
    fi
    if [ "$lint_failed" -eq 1 ]; then
        fail
    fi
else
    echo "  (no .py files staged)"
fi

# ── Check 5: project tests ────────────────────────────────────────

header "tests"
# Map changed paths to project test suites
declare -A projects_hit
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        projects/aiserver/*) projects_hit[aiserver]=1 ;;
        projects/rp/*)       projects_hit[rp]=1 ;;
        projects/3dml/*)     projects_hit[3dml]=1 ;;
        projects/coach/*)    projects_hit[coach]=1 ;;
    esac
done <<< "$STAGED_FILES"

if [ ${#projects_hit[@]} -eq 0 ]; then
    echo "  (no project files staged)"
else
    test_failed=0
    for proj in "${!projects_hit[@]}"; do
        test_dir="$REPO_ROOT/projects/$proj/tests"
        [ -d "$test_dir" ] || continue

        venv="$REPO_ROOT/projects/$proj/.venv/bin/python"
        if [ -x "$venv" ]; then
            py="$venv"
        else
            py="python3"
        fi

        echo "  running $proj tests..."
        extra_args=()
        if [ "$proj" = "3dml" ]; then
            extra_args=(--ignore=tests/test_ui.py)
        fi
        if ! (cd "$REPO_ROOT/projects/$proj" && PYTHONPATH="$REPO_ROOT" "$py" -m pytest tests/ -x -q "${extra_args[@]}" 2>&1); then
            echo "  FAIL: $proj tests"
            test_failed=1
        fi
    done
    if [ "$test_failed" -eq 1 ]; then
        fail
    fi
fi

# ── Result ──────────────────────────────────────────────────────────

echo ""
if [ "$FAILED" -eq 1 ]; then
    echo "Pre-commit: FAILED (fix errors above)"
    exit 1
else
    echo "Pre-commit: OK"
    exit 0
fi
