{
  "permissions": {
    "allow": [
      "Bash(/d/prg/plum/.gitignore:*)",
      "Bash(/d/prg/plum/.env.example:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(chmod +x:*)",
      "Bash(git status)",
      "Bash(bash:*)",
      "Bash(do echo:*)",
      "Bash(python3:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(LOG_VERBOSE=true bash:*)",
      "Bash(cd /d/prg/plum && git status)",
      "Bash(cd /d/prg/plum && git log --oneline -5)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(xxd:*)",
      "Bash(git:*)",
      "Bash(shellcheck:*)",
      "Bash(node:*)",
      "Bash(sudo apt-get:*)",
      "Bash(echo:*)",
      "Bash(ruff:*)",
      "Bash(pip3 install:*)",
      "Bash(pipx list:*)",
      "Bash(pipx install:*)",
      "Bash(test:*)",
      "Bash(gh repo:*)",
      "Bash(gh auth:*)",
      "Bash(gh:*)",
      "Bash(jq:*)",
      "Bash(/tmp/test_hook_with_spaces.sh:*)",
      "Bash(/tmp/test_diff_filter_meaning.sh:*)",
      "Bash(/tmp/test_diff_filter_lowercase.sh:*)",
      "Bash(gh issue:*)",
      "Bash(tar tzf:*)",
      "Bash(tar xzf:*)",
      "Bash(cp:*)",
      "Bash(sed:*)",
      "Bash(echo No hardcoded secrets found:*)",
      "Bash(gh pr:*)",
      "Bash(nvidia-smi:*)",
      "WebSearch",
      "Bash(ollama:*)",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-env.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-worktree-danger.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-master-commits.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-shell.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
